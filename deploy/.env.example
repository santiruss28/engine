# =============================================================================
# OpenClaw - Variables de entorno
# =============================================================================
# Copia este archivo como .env y completá los valores:
#   cp .env.example .env
# =============================================================================

# Token de acceso al Gateway (generá uno con: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# Puertos (dejar defaults a menos que haya conflictos)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Bind mode: lan | loopback | tailnet | auto
OPENCLAW_GATEWAY_BIND=lan

# Timezone
OPENCLAW_TZ=America/Argentina/Buenos_Aires

# --- API Keys (configurá al menos una) ---

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# --- Opcionales ---

# Permitir WebSocket inseguro en red privada
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=true
